<h2>ログイン</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

  <div class="field">
    <p><%= f.label :email, "メールアドレス" %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password, "パスワード" %></p>
    <p><%= f.password_field :password, autocomplete: "current-password" %></p>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="field">
      <label>
        <%= f.check_box :remember_me %>
        ログイン状態を保持する
      </label>
    </div>
  <% end %>

  <div class="actions">
    <%= f.submit "ログイン", class: "button" %>
  </div>

<% end %>

<p>
  アカウントをお持ちでない方
  <%= link_to "新規登録", new_registration_path(resource_name) %>
</p>