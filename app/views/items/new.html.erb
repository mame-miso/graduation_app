<% content_for :page_title, "アイテム登録" %>

<div class="card">

  <%= form_with model: [@place, @item], local: true do |f| %>
    <div class="form-group">
      <%= f.label :image, "写真を撮影して追加" %>
      <%= f.file_field :image,
        accept: "image/*",
        capture: "environment",
        onchange: "previewImage(event)" %>

      <!-- ここにプレビュー -->
      <img id="preview" style="display:none; width:200px; margin-top:10px;">
    </div>

    <div>
      <%= f.submit "登録" %>
    </div>
  <% end %>
</div>

<div class="form-actions">
  <%= link_to "← 収納したアイテムへ戻る", place_path(@place), class: "button secondary-button " %>
</div>