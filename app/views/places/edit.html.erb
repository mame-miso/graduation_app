<% content_for :page_title, "場所を編集" %>

<% if @place.errors.any? %>
  <div class="flash-message alert">
    <% @place.errors.full_messages.each do |message| %>
      <p><%= message %></p>
    <% end %>
  </div>
<% end %>

<div class="card">
  <%= form_with model: @place do |f| %>
    <div class="form-group">
      <%= f.label :name, "場所の写真" %>
      <%= f.file_field :cover_image,
        accept: "cover_image/*",
        capture: "environment",
        onchange: "previewImage(event)" %>

      <!-- ここにプレビュー -->
      <img id="preview" style="display:none; width:200px; margin-top:10px;">
    </div>

    <% if @place.cover_image.attached? %>
      <div class="form-group">
        <%= image_tag @place.cover_image, width: 200 %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :name, "場所名" %>
      <%= f.text_field :name %>
    </div>

    <div>
      <%= f.submit "更新" %>
    </div>
  <% end %>
</div>

<div class="form-actions">
  <%= link_to "← 収納場所へ戻る", places_path, class: "button secondary-button " %>
</div>