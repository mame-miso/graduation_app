<h1>場所詳細</h1>

<div class="card">
  <p><strong>場所名:</strong> <%= @place.name.presence || "写真で登録した場所" %></p>

  <% if @place.cover_image.attached? %>
    <p><strong>場所の写真:</strong></p>
    <%= image_tag @place.cover_image, width: 240 %>
  <% end %>

  <div class="place-actions">
    <%= link_to "中身の写真を追加", new_place_item_path(@place), class: "button" %>
    <%= link_to "編集", edit_place_path(@place), class: "button" %>
    <%= button_to "削除", place_path(@place), method: :delete, data: { turbo_confirm: "削除しますか？" } %>
    <%= link_to "場所一覧へ", places_path %>
  </div>
</div>

<h2>中身の写真一覧</h2>

<% if @place.items.any? %>
  <% @place.items.each do |item| %>
    <% if item.image.attached? %>
      <div class="card item-image">
        <%= link_to url_for(item.image), target: "_blank", rel: "noopener" do %>
          <%= image_tag item.image, width: 220 %>
        <% end %>
        <div class="place-actions">
          <%= button_to "削除", place_item_path(@place, item), method: :delete, data: { turbo_confirm: "削除しますか？" } %>
        </div>
      </div>
    <% end %>
  <% end %>
<% else %>
  <div class="card">
    <p>まだ中身の写真はありません</p>
  </div>
<% end %>