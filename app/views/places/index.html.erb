<% content_for :page_title, "収納場所" %>

<div class="places-page">
  <% if @places.empty? %>
    <div class="empty-state">
      <p class="empty-title">まだ収納場所が登録されていません</p>
      <p class="empty-text">まずは、物をしまっている場所を登録してみましょう。</p>

      <%= link_to "＋ 収納場所追加", new_place_path, class: "button primary-button" %>
    </div>
  <% else %>
    <ul class="place-list">
      <% @places.each do |place| %>
        <li class="place-card">
          <%= link_to place_path(place) do %>
            <% if place.cover_image.attached? %>
               <%= image_tag place.cover_image, class: "place-thumbnail" %>
             <% else %>
               <div class="place-thumbnail place-thumbnail-empty">
                 No Image
               </div>
             <% end %>
           <% end %>

          <%= link_to place_path(place), class: "place-name-overlay" do %>
            <%= place.name.presence || "名称未設定" %>
          <% end %>

          <%= link_to edit_place_path(place), class: "place-edit-button", aria: { label: "編集" } do %>
            <%= image_tag "pen.svg", alt: "編集" %>
          <% end %>

          <%= button_to "",
                place_path(place),
                method: :delete,
                data: { turbo_confirm: "削除しますか？" },
                class: "place-delete-button",
                aria: { label: "削除" } %>
        </li>
      <% end %>
    </ul>

    <div class="fixed-add-button-wrap">
      <%= link_to "＋ 収納場所を追加", new_place_path, class: "button primary-button large-add-button" %>
    </div>
  <% end %>
</div>
