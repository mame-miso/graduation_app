<h1>場所一覧</h1>

<%= link_to "場所を追加", new_place_path %>

<ul>
  <% @places.each do |place| %>
    <li>
      <%= link_to place.name, place_path(place) %>
      <%= link_to "編集", edit_place_path(place) %>
      <%= button_to "削除", place_path(place), method: :delete, data: { turbo_confirm: "削除しますか？" } %>
    </li>
  <% end %>
</ul>